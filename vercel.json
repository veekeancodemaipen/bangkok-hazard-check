{
  "version": 2,
  "name": "bangkok-journey-intelligence",
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" },
    { "src": "*.geojson", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/safepath_demo_v2.html" },
    { "src": "/demo", "dest": "/safepath_demo_v2.html" },
    { "src": "/app", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
